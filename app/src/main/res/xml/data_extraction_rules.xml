<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for API 31+.
    Explicitly include only the DaysSince prefs file for both cloud backup
    and device-to-device transfer.
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Legacy single-counter SharedPreferences (kept for one-time migration). -->
        <include domain="sharedpref" path="dayssince_prefs.xml" />
        <!-- Current DataStore (Preferences): milestones list + widget bindings. -->
        <include domain="file" path="datastore/dayssince_store.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="dayssince_prefs.xml" />
        <include domain="file" path="datastore/dayssince_store.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
