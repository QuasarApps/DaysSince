<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-backup rules for API 30 and below.
    Explicitly include only the DaysSince prefs file so backups are intentional,
    not a side-effect of the default "include everything" behaviour.
    See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <include domain="sharedpref" path="dayssince_prefs.xml" />
</full-backup-content>
