<resources>
    <!-- Canonical app name, localized per-locale (see values-<lang>/strings.xml). Both build variants
         resolve the `${appLabel}` manifest placeholder to this string, so the launcher label is
         localized; the debug build is told apart by its `.debug` applicationId, not a label suffix. -->
    <string name="app_name">Days Since</string>

    <!-- Accent color names. User-facing only as the accent picker's accessibility labels. -->
    <string name="accent_dynamic">Dynamic</string>
    <string name="accent_indigo">Indigo</string>
    <string name="accent_violet">Violet</string>
    <string name="accent_rose">Rose</string>
    <string name="accent_sunset">Sunset</string>
    <string name="accent_emerald">Emerald</string>
    <string name="accent_ocean">Ocean</string>
    <string name="accent_slate">Slate</string>

    <!-- Shared actions -->
    <string name="action_save">Save</string>
    <string name="action_cancel">Cancel</string>
    <string name="action_ok">OK</string>
    <string name="action_edit">Edit</string>
    <string name="action_delete">Delete</string>

    <!-- Home screen -->
    <string name="home_title">Days Since</string>
    <string name="home_fab_new">New</string>
    <!-- Accessibility label for the add FAB (its visible "New" text is not exposed to TalkBack). -->
    <string name="home_fab_content_description">Add milestone</string>
    <!-- translator: standalone caption shown under a large standalone number; not adjacent to it,
         so no number agreement is needed. -->
    <string name="card_days_since_label">DAYS SINCE</string>
    <!-- %1$s = localized long date, %2$s = localized time. e.g. "On January 1, 2026 at 9:00 AM" -->
    <string name="card_on_date_at_time">On %1$s at %2$s</string>
    <string name="empty_title">No milestones yet</string>
    <string name="empty_subtitle">Track the days since something that matters to you.</string>
    <string name="empty_cta">Add your first milestone</string>

    <!-- Detail screen -->
    <string name="detail_back_content_description">Back</string>
    <string name="detail_more_options_content_description">More options</string>
    <!-- translator: the next three are standalone unit captions under large standalone numbers
         (a dashboard-style readout); they are not placed next to the number, so no plural
         agreement is needed. -->
    <string name="detail_days_label">DAYS</string>
    <string name="detail_hours_label">HOURS</string>
    <string name="detail_minutes_label">MINUTES</string>
    <!-- %1$s = localized long date, %2$s = localized time. e.g. "since June 15, 2025 at 9:30 AM" -->
    <string name="detail_since_date_at_time">since %1$s at %2$s</string>
    <string name="detail_widget_hint">Add a widget from your home screen to keep this in view.</string>
    <string name="detail_delete_dialog_title">Delete milestone?</string>
    <!-- %1$s = milestone title -->
    <string name="detail_delete_dialog_message">This removes “%1$s” and any widgets using it.</string>
    <string name="detail_missing">This milestone is no longer available.</string>
    <string name="detail_go_back">Go back</string>

    <!-- Add / edit milestone screen -->
    <string name="edit_title_new">New milestone</string>
    <string name="edit_title_edit">Edit milestone</string>
    <string name="edit_title_field_label">Title</string>
    <string name="edit_title_field_placeholder">e.g. Quit smoking</string>
    <string name="edit_field_date">Date</string>
    <string name="edit_field_time">Time</string>
    <string name="edit_accent_header">Accent</string>
    <!-- Fallback title used when the user leaves the title blank. -->
    <string name="milestone_default_title">Milestone</string>

    <!-- Widget configuration screen -->
    <string name="widget_config_title">Choose a milestone</string>
    <string name="widget_config_transparent_title">Transparent background</string>
    <string name="widget_config_transparent_subtitle">Show just the number on your wallpaper.</string>
    <string name="widget_config_empty_subtitle">Open Days Since to add one, then place the widget again.</string>
    <string name="widget_config_open_app">Open Days Since</string>
    <!-- %1$d = whole days, %2$s = localized long date. e.g. "12 days · since January 1, 2026".
         The count is passed both as the quantity selector and as %1$d. -->
    <plurals name="widget_config_row_subtitle">
        <item quantity="one">%1$d day · since %2$s</item>
        <item quantity="other">%1$d days · since %2$s</item>
    </plurals>
</resources>
