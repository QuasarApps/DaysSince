<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificates for the Google Play Services downloadable-font provider. This is the standard,
  app-agnostic certificate set. If the display font (Space Grotesk) does not render on a device,
  regenerate this file via Android Studio's downloadable-fonts dialog; the app falls back to the
  platform font in the meantime.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
             ...
        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
             ...
        </item>
    </string-array>
</resources>
