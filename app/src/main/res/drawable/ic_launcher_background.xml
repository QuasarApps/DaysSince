<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon background. A solid dark fill that matches the foreground tile's baked-in
    background, so the composited icon stays consistent across launchers / mask shapes and on
    older devices that fall back to the legacy square icon.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2B2C30" />
</shape>
