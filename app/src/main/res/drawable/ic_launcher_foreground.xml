<?xml version="1.0" encoding="utf-8"?>
<!-- White clock glyph centered in the adaptive-icon safe zone (time elapsed = "days since"). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- ring -->
    <path
        android:pathData="M30,54 a24,24 0 1,0 48,0 a24,24 0 1,0 -48,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round" />
    <!-- minute hand -->
    <path
        android:pathData="M54,54 L54,39"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round" />
    <!-- hour hand -->
    <path
        android:pathData="M54,54 L65,60"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round" />
    <!-- hub -->
    <path
        android:pathData="M50,54 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z"
        android:fillColor="#FFFFFF" />
</vector>
