<?xml version="1.0" encoding="UTF-8"?>
<!--
    Project-level lint configuration.

    Most entries here silence well-understood false positives that show up in
    `lintRelease`. Real findings should be fixed at the source rather than
    added here.
-->
<lint>

    <!-- font_certs.xml is auto-generated by Android Studio's downloadable-fonts
         flow and contains base64-encoded certificates. Lint's spell-checker
         flags substrings inside the base64 blob; none of them are typos. -->
    <issue id="Typos">
        <ignore path="src/main/res/values/font_certs.xml" />
    </issue>

    <!-- The widget XML descriptors deliberately use API 31+ attributes
         (previewLayout, targetCellWidth, targetCellHeight). They are ignored
         on API 26-30 and used on 31+; that's the whole point. -->
    <issue id="UnusedAttribute">
        <ignore path="src/main/res/xml/days_since_widget_info.xml" />
        <ignore path="src/main/res/xml/days_hours_minutes_since_widget_info.xml" />
    </issue>

    <!-- targetSdk = 35 is the current latest Android (15) at the time of this
         release. Lint is informational here, not a real version-skew finding. -->
    <issue id="OldTargetApi" severity="informational" />

    <!-- User-facing strings must be resources (for localization), not hardcoded literals. This
         guards XML (android:text); the deliberate sample numbers in the widget preview layouts
         carry their own tools:ignore. Note: stock lint does NOT cover Compose `Text("literal")`,
         so Compose string literals still rely on code review. -->
    <issue id="HardcodedText" severity="error" />

    <!-- TODO(icon): the adaptive icon foreground PNG already bakes in its dark
         background, so launchers can't extract a monochrome silhouette. Adding
         a real monochrome variant needs the original icon source (vector). Once
         that lands, delete this entry so the warning starts surfacing again. -->
    <issue id="MonochromeLauncherIcon" severity="ignore" />

</lint>
